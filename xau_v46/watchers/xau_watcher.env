# =========================
# XAU Telegram Watcher Env
# =========================
# TELEGRAM_ENABLED=true
# --- Telegram ---
TG_BOT_TOKEN=8448935427:AAFPEo6p1mmLIUR3PavzBwZOSFEFjpg70xY
TG_CHAT_ID=6842274522

# --- Log source (legacy; still used if WATCH_MODE=log) ---
WATCH_LOG_DIR=logs\xau_v4.6
WATCH_LOG_GLOB=xau_v46_*.log

# --- Watch mode: "log" (legacy) or "jsonl" (preferred) ---
WATCH_MODE=jsonl
# --- JSONL stream (preferred) ---
# WATCH_JSONL_FILE=logs\xau_v4.6\xau_events_{date}.jsonl
WATCH_JSONL_GLOB=logs\xau_v4.6\xau_events_*.jsonl
# --- Persist offset across restarts ---
WATCH_STATE_FILE=logs\xau_v4.6\xau_watcher.state.json

# --- Only used for WATCH_MODE=log (safe to keep) ---
WATCH_EVENT_PREFIX=EVENT

# --- Event filters (comma-separated; must match top-level "event") ---
# WATCH_INCLUDE_EVENTS=TRADE_START,TRADE_END,ERROR,BLOCKED,EXECUTED,FAILED
WATCH_INCLUDE_EVENTS=ERROR,BLOCKED,EXECUTED,FAILED
WATCH_EXCLUDE_EVENTS=TRADE_START,TRADE_END,SKIP,RISK,ORDER_SEND,ORDER_RESULT

# --- Optional: only alert when DECISION has side LONG/SHORT (not empty) ---
WATCH_DECISION_REQUIRE_SIDE=true

# --- Anti-spam / guardrails ---
WATCH_DEDUPE_WINDOW_SEC=900
WATCH_MIN_SECONDS_BETWEEN_ALERTS=0.2
WATCH_MAX_ALERTS_PER_5MIN=60

# --- Formatting ---
WATCH_SHOW_RAW_LINE=false
WATCH_MAX_MESSAGE_CHARS=3500

# --- Start position ---
WATCH_START_AT=tail

# --- Operational ---
WATCH_ATTACH_MESSAGE=true
WATCH_POLL_INTERVAL_SEC=0.5

# --- Heartbeat / Health ---
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL_SEC=1800
HEARTBEAT_SILENCE_ALERT_SEC=900
HEARTBEAT_INCLUDE_FILE=true
HEARTBEAT_INCLUDE_LAST_EVENT=true
WATCH_ATTACH_MESSAGE=true
WATCH_POLL_INTERVAL_SEC=0.5

# --- Heartbeat / Health ---
# HEARTBEAT_ENABLED=true
# HEARTBEAT_INTERVAL_SEC=1800          # 30 minutes
# HEARTBEAT_SILENCE_ALERT_SEC=900      # alert if no EVENT lines for 15 minutes (0 disables)
# HEARTBEAT_INCLUDE_FILE=true          # include current log file name
# HEARTBEAT_INCLUDE_LAST_EVENT=true    # include last event + how long ago
