# ==========================================================
# Agentic Trader v4.6 — XAUUSD Configuration Environment
# ----------------------------------------------------------
# This file governs the full XAU module:
# • Connection (MT5)
# • Guardrails & execution
# • Dynamic lots & confidence scaling
# • ATR/Volatility parameters
# • Trust memory & adaptive filters
# • SL/TP scaling and trade policy
# ==========================================================

# ==========================================================
# MT5 CONNECTION (LIVE)
# ==========================================================
EXECUTION_MODE=live
BROKER_BACKEND=mt5
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_LOGIN=18023893
MT5_PASSWORD=VishyVahis786!
MT5_SERVER=VTMarkets-Live 3

# ==========================================================
# AGENT CORE CONFIGURATION
# ==========================================================
AGENT_NAME=XAU_V46

# Preferred by executor & agent
XAU_AGENT_SYMBOLS=XAUUSD-ECNc

# Generic fallback (kept)
AGENT_SYMBOLS=XAUUSD-ECNc

XAU_LOG_LEVEL=INFO
XAU_TIMEFRAME=M15              # primary trading timeframe (used by agent)
XAU_HISTORY_BARS=240           # bars to load for context

# Main agent loop interval (60s default)
LOOP_INTERVAL=60

# ==========================================================
# GUARDRAILS & RISK CONTROL
# ==========================================================

XAU_AGENT_MAX_OPEN=12
XAU_AGENT_MAX_PER_SYMBOL=1

# Cooldown between entries for the same symbol
XAU_COOLDOWN_SEC=300

# Prevent same-side re-entry / stacking
XAU_BLOCK_SAME_DIRECTION=True
XAU_MAX_SAME_DIR_PER_SYMBOL=1
XAU_SAME_DIR_COOLDOWN_SEC=300
XAU_SAME_DIR_BLOCK_SEC=600

# ==========================================================
# DYNAMIC LOT SIZING
# ==========================================================
XAU_MIN_LOTS=0.01
XAU_MAX_LOTS=0.10
XAU_CONF_WEIGHT=0.70           # confidence weighting for scaling
XAU_LOT_STEP=0.01              # broker volume step

# ==========================================================
# VOLATILITY / ATR CONFIGURATION
# ==========================================================
ATR_ENABLED=True
ATR_PERIOD=14
XAU_ATR_PERIOD=14              # Used by xau_features_v46.py

# "Sweet-spot" ATR range for confidence adjustment
XAU_ATR_TARGET_MIN=0.0010      # 0.10% (quiet market)
XAU_ATR_TARGET_MAX=0.0040      # 0.40% (high volatility)

# Minimum ATR% for policy gating – gold needs some volatility
XAU_MIN_ATR_PCT=0.0010         # 0.10%

# Legacy ATR-based SL/TP multipliers (kept for compatibility)
ATR_SL_MULT=2.0
ATR_TP_MULT=3.0

# --- Fix ATR multipliers key mismatch ---
XAU_ATR_CONF_MULT_QUIET=0.65
XAU_ATR_CONF_MULT_NORMAL=1.00
XAU_ATR_CONF_MULT_HOT=0.7

# ==========================================================
# TRUST MEMORY & CONFIDENCE ENGINE
# ==========================================================
XAU_TRUST_WEIGHT=0.4
XAU_TRUST_DECAY_BARS=600
XAU_TRUST_DECAY_STEP_HIGH=0.005
XAU_TRUST_DECAY_STEP_LOW=0.002
XAU_CONFIDENCE_LOCK_N=3
XAU_CONFIDENCE_RESET_N=3
XAU_CONFIDENCE_TRUST_N=5

# ==========================================================
# 🎛 TRADE POLICY (STRICT / FLEXIBLE / AGGRESSIVE)
# ==========================================================
# Confidence multipliers per ATR regime
# XAU_CONF_MULT_QUIET=0.65
# XAU_CONF_MULT_NORMAL=1.00
# XAU_CONF_MULT_HOT=0.75

XAU_TRADE_POLICY=flexible

XAU_MIN_CONF_STRICT=0.58
XAU_MIN_CONF_FLEX=0.50 # Changed from 0.55 to 0.50 
XAU_MIN_CONF_AGGR=0.40
XAU_FALLBACK_MIN_CONF=0.45    # min conf if no data

XAU_RSI_LONG_TH=60
XAU_RSI_SHORT_TH=37

# ==========================================================
# TIMEFRAMES & HISTORY
# ==========================================================
BAR_TIMEFRAME_M15=15
BAR_TIMEFRAME_H1=16385
BAR_HISTORY_BARS=240

# ==========================================================
# INDICATOR PARAMETERS (XAU-specific)
# ==========================================================
XAU_EMA_FAST=20
XAU_EMA_SLOW=50
XAU_RSI_PERIOD=14

# ==========================================================
# SL/TP SCALING (Confidence × Trust × ATR)
# ==========================================================
XAU_SL_MIN=40
XAU_TP_MIN=80
XAU_SL_DEFAULT=150
XAU_TP_DEFAULT=300
XAU_SLTP_ATR_MULT=1.0

# ==========================================================
# BASELINE RISK PARAMETERS (LEGACY – NOT USED BY v4.6 DECIDER)
# ==========================================================
XAU_SL_POINTS_BASE=300
XAU_TP_POINTS_BASE=600
XAU_MIN_CONFIDENCE=0.55

# New Parameters for ensuring we dont trade to avoid session risk 
# (xau_session_risk_v46.py)

XAU_SRC_MAX_DD_DAY_ACC=3000        # stop all XAU if account DD day ≤ -3000
XAU_SRC_MAX_DD_DAY_SYM=1500        # per-symbol (XAUUSD-ECNc) DD
XAU_SRC_MAX_CONSEC_LOSSES=3      # max 3 losing trades in a row
XAU_SRC_COOL_OFF_MIN=30          # cooloff duration (minutes)

# ==========================================================
#  MT5 EXECUTION PARAMETERS
# ==========================================================
MT5_DEVIATION=100
XAU_STOP_WIDEN_MULT=1.5

# ==========================================================
# XAU ATR REGIMES (Quiet / Normal / Hot)
# ==========================================================
# Values are in FRACTION (0.0012 = 0.12%)

XAU_ATR_QUIET_MAX=0.0012       # ≤ 0.12%  -> QUIET
XAU_ATR_NORMAL_MAX=0.0030      # ≤ 0.30%  -> NORMAL
# > XAU_ATR_NORMAL_MAX         #         -> HOT

# Existing targets remain for confidence shaping
# XAU_ATR_TARGET_MIN=0.0010    # already in your env (0.10%)
# XAU_ATR_TARGET_MAX=0.0040    # already in your env (0.40%)

# ==========================================================
# XAU TRADING WINDOW (IDX-style; optional)
# ==========================================================
XAU_TRADING_WINDOW_START=00:00
XAU_TRADING_WINDOW_END=23:59
XAU_TRADING_DAYS=1,2,3,4,5     # Mon–Fri

# ==========================================================
# Swing behaviour flags (for future decider wiring)
# ==========================================================
XAU_SWING_QUIET_ONLY=true      # only allow swing-lock logic in QUIET regime

# Change 4 — chop protection via EMA gap
XAU_CHANGE4_GAP_CLAMP=1
XAU_EMA_GAP_MIN_NORMAL=1.10
XAU_EMA_GAP_MIN_RANGE=1.30

# Change 4 enhancements (minimal)
XAU_DYNAMIC_GAP_BY_ATR=1
XAU_GAP_FACTOR_MIN=0.85
XAU_GAP_FACTOR_MAX=1.35

# Loss-adaptive widening via trust
XAU_GAP_TRUST_PIVOT=0.55
XAU_GAP_TRUST_PENALTY=0.80

XAU_ATR_SLTP_MULT_QUIET=1.00
XAU_ATR_SLTP_MULT_NORMAL=1.00
XAU_ATR_SLTP_MULT_HOT=1.00

XAU_H1_CONTEXT_ENABLED=true
XAU_H1_TIMEFRAME=H1
XAU_H1_HISTORY_BARS=300

XAU_H1_RSI_TREND_UP=52
XAU_H1_RSI_TREND_DOWN=48

XAU_TREND_ONLY=false

XAU_ALERTS_ENABLED=true
TELEGRAM_BOT_TOKEN=8448935427:AAFPEo6p1mmLIUR3PavzBwZOSFEFjpg70xY
TELEGRAM_CHAT_ID=6842274522

# ==========================================================
# DEBUG H1 Context PARAMETERS
# ==========================================================
XAU_DEBUG_H1_CONTEXT=true

