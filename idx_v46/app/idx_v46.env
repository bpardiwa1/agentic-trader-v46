# ==========================================================
# Agentic Trader v4.6 — Indices (idx_v46) Environment
# ==========================================================

# ----------------------------------------------------------
# Core / Logging
# ----------------------------------------------------------
AGENT_NAME=IDX_V46
AGENT_SYMBOLS=NAS100.s,UK100.s,HK50.s
IDX_AGENT_SYMBOLS=NAS100.s,UK100.s,HK50.s

LOG_LEVEL=INFO
IDX_LOG_LEVEL=INFO
LOOP_INTERVAL=60

# ----------------------------------------------------------
# JSONL Events (Watcher feed)
# ----------------------------------------------------------
IDX_EVENTS_DIR=logs/idx_v4.6
IDX_EVENTS_DAILY_ROTATE=true
IDX_EVENTS_LOG_TO_MAIN=false

# ----------------------------------------------------------
# Broker Connection
# ----------------------------------------------------------
MT5_LOGIN=18023893
MT5_PASSWORD=VishyVahis786!
MT5_SERVER=VTMarkets-Live 3
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_DEVIATION=80

# ----------------------------------------------------------
# Timeframe & History
# ----------------------------------------------------------
IDX_TIMEFRAME=M15
IDX_HISTORY_BARS=240

# ----------------------------------------------------------
# Indicators
# ----------------------------------------------------------
IDX_EMA_FAST=20
IDX_EMA_SLOW=50
IDX_RSI_PERIOD=14
IDX_RSI_LONG_TH=58
IDX_RSI_SHORT_TH=42
IDX_ATR_PERIOD=14

# Feature base weights (used in idx_features_v46)
IDX_CONF_BASE_WEIGHT_EMA=0.5
IDX_CONF_BASE_WEIGHT_RSI=0.5

# ----------------------------------------------------------
# ATR Gating & Scaling
# ----------------------------------------------------------
# Target ATR band where strategy is "happiest"
IDX_ATR_TARGET_MIN=0.0008      # 0.08%: still OK, but a bit sleepy
IDX_ATR_TARGET_MAX=0.0060      # 0.60%: upper bound of "happy" volatility

# Points multiplier (index prices → ATR%)
IDX_ATR_POINTS_MULT=10000

# Minimum ATR% required to consider a setup "tradable"
# 0.0010 ~ 0.10% (≈ 17 pts on NAS100 @ 17k)
IDX_MIN_ATR_PCT=0.0008

# ATR regime thresholds (used for tagging quiet/normal/hot)
# < 0.0020  (0.20%)   -> atr_level = quiet
# 0.0020–0.0050       -> atr_level = normal
# > 0.0050  (0.50%)   -> atr_level = hot
IDX_ATR_QUIET_PCT=0.0020
IDX_ATR_HOT_PCT=0.0050


# Confidence reaction to ATR regimes
# quiet: trim a bit (sleepy), but still trade
# hot:   trim more (jumpy), be cautious
IDX_ATR_QUIET_CONF_MULT=0.95
IDX_ATR_HOT_CONF_MULT=0.60

# Regime-specific confidence floors
# Base floors still come from:
#   IDX_MIN_CONF_STRICT / FLEX / AGGR (by policy)
IDX_CONF_FLOOR_NORMAL=0.52
IDX_CONF_FLOOR_QUIET=0.45
IDX_CONF_FLOOR_HOT=0.60

# ----------------------------------------------------------
# STRICT / FLEX / AGGRESSIVE Trade Policy
# ----------------------------------------------------------
IDX_TRADE_POLICY=flexible
IDX_MIN_CONF_STRICT=0.58
IDX_MIN_CONF_FLEX=0.52
IDX_MIN_CONF_AGGR=0.45

# ----------------------------------------------------------
# Per-symbol min confidence overrides (Option C hardening)
# Applies to the active IDX_TRADE_POLICY via:
#   IDX_MIN_CONF_<POLICY>_<BASE>
# where BASE is NAS100 / UK100 / HK50 (derived from symbol).
# ----------------------------------------------------------
IDX_MIN_CONF_FLEX_NAS100=0.58
IDX_MIN_CONF_FLEX_UK100=0.58
# Keep HK50 more permissive (currently profitable)
IDX_MIN_CONF_FLEX_HK50=0.50
# Quality bar bump
IDX_NAS100_MIN_CONF_BUMP=0.03
IDX_EMA_GAP_MIN_POINTS_NAS100=3.0
IDX_EMA_GAP_MIN_POINTS_UK100=12
IDX_RSI_SOFT_LONG_MIN_UK100=55
IDX_RSI_SOFT_SHORT_MAX_UK100=45
IDX_EMA_GAP_MIN_POINTS_HK50=12

# ----------------------------------------------------------
# SL/TP Baselines & Multipliers
# ----------------------------------------------------------
IDX_SL_POINTS_BASE=100
IDX_TP_POINTS_BASE=200
IDX_SL_ATR_MULT=1.5
IDX_TP_ATR_MULT=3.0

# Confidence-based SL/TP tuning
IDX_CONF_SLTP_WEIGHT=0.5
IDX_SL_MIN_POINTS=20
IDX_TP_MIN_POINTS=40

# ATR floors and minimum RR for indices
IDX_SL_ATR_FLOOR=1.0      # Min SL = 1.0 × ATR
IDX_TP_ATR_FLOOR=1.5      # Min TP = 1.5 × ATR
IDX_MIN_RR=1.6            # TP >= SL * RR

# ----------------------------------------------------------
# Guardrails (agent-level)
# ----------------------------------------------------------
IDX_AGENT_MAX_OPEN=12          # global max open trades (all symbols)
IDX_AGENT_MAX_PER_SYMBOL=1     # default per-symbol cap (overridden below)
IDX_COOLDOWN_SEC=120            # global cooldown after a trade
IDX_BLOCK_SAME_DIRECTION=False

# Legacy but used by agent (not policy gate)
IDX_MIN_CONFIDENCE=0.52

# ----------------------------------------------------------
# Optional Soft EMA/RSI Signal Control
# ----------------------------------------------------------
IDX_ALLOW_SOFT_SIGNALS=true
# Softer nudge so quiet markets can still trade
IDX_SOFT_SIGNAL_WEIGHT=0.9

# ----------------------------------------------------------
# Dynamic Lots & Trust
# ----------------------------------------------------------
# Global defaults (fallback if no per-symbol override)
IDX_MIN_LOTS=0.10
IDX_MAX_LOTS=0.30
IDX_TRUST_WEIGHT=0.40

# Per-symbol lot overrides (indices)

# HK50: slightly larger range, but still modest
HK50_MIN_LOTS=0.10
HK50_MAX_LOTS=0.30

# NAS100: more volatile, keep the top end tighter
NAS100_MIN_LOTS=0.10
NAS100_MAX_LOTS=0.20

# UK100: medium; allow a bit more than NAS100, less than HK50
UK100_MIN_LOTS=0.10
UK100_MAX_LOTS=0.25

# Quiet/hot volatility lot modifiers (used by scaler)
IDX_QUIET_LOT_MULT=0.9
IDX_HIGH_VOL_LOT_MULT=0.8

# Alignment-based lot scaling
IDX_LOT_EDGE_CONF=0.0
IDX_LOT_FACT_FULL_ALIGN=1.0
IDX_LOT_FACT_MIXED=0.60
IDX_LOT_FACT_OVERRIDE=0.50
IDX_LOT_FACT_EDGE=0.40

# Trust engine parameters (used in idx_trust_engine_v46)
IDX_TRUST_MIN=0.40
IDX_TRUST_MAX=0.95
IDX_TRUST_DEFAULT=0.50
IDX_TRUST_INC_SUCCESS=0.05
IDX_TRUST_DEC_FAIL=0.10
IDX_TRUST_DECAY_SEC=540000

# ----------------------------------------------------------
# Execution
# ----------------------------------------------------------
IDX_STOP_WIDEN_MULT=1.5
IDX_PIP_MODE=index_point

# ----------------------------------------------------------
# Global Trading Session (KL time)
# ----------------------------------------------------------
IDX_TRADE_START=00:00
IDX_TRADE_END=23:59
IDX_TRADE_DAYS=1,2,3,4,5

# ----------------------------------------------------------
# Per-Symbol Trading Sessions (KL time)
# ----------------------------------------------------------
# NASDAQ (US session)
IDX_TRADE_START_NAS100=21:15
IDX_TRADE_END_NAS100=00:30
IDX_TRADE_DAYS_NAS100=1,2,3,4,5

# FTSE (UK session)
IDX_TRADE_START_UK100=16:00
IDX_TRADE_END_UK100=22:30
IDX_TRADE_DAYS_UK100=1,2,3,4,5

# Hang Seng (HK session)
IDX_TRADE_START_HK50=09:15
IDX_TRADE_END_HK50=16:30
IDX_TRADE_DAYS_HK50=1,2,3,4,5

# ----------------------------------------------------------
# Override Block (LEGACY – used by agent, not policy gate)
# ----------------------------------------------------------
IDX_OVERRIDE_ENABLE=true
IDX_OVERRIDE_MIN_CONF=0.60
IDX_OVERRIDE_MIN_TRUST=0.60
IDX_OVERRIDE_MIN_ATR_PCT=0.0007
IDX_OVERRIDE_MAX_GAP_POINTS=15.0
IDX_OVERRIDE_RSI_BULL=58.0
IDX_OVERRIDE_RSI_BEAR=42.0

# ----------------------------------------------------------
# IDX Risk Management (per-symbol SRC)
# ----------------------------------------------------------

# Global account-level stop (all indices together)
IDX_SRC_MAX_DD_DAY_ACC=3000      # stop all indices if total DD hits -3000

# Default per-symbol daily DD / streak / cool-off (used if no _{BASE} override)
IDX_SRC_MAX_DD_DAY_SYM=2000
IDX_SRC_MAX_CONSEC_LOSSES=3
IDX_SRC_COOL_OFF_MIN=10

# NAS100.s  → base = NAS100 (stricter)
IDX_SRC_MAX_DD_DAY_SYM_NAS100=1500
IDX_SRC_MAX_CONSEC_LOSSES_NAS100=2
IDX_SRC_COOL_OFF_MIN_NAS100=30

# HK50.s    → base = HK50 (more forgiving)
IDX_SRC_MAX_DD_DAY_SYM_HK50=2500
IDX_SRC_MAX_CONSEC_LOSSES_HK50=4
# Cool-off falls back to default
# Cool-off period for UK100 after breach (minutes)
IDX_SRC_COOL_OFF_MIN_HK50=10

# UK100.s  → base = UK100 (middle ground)
IDX_SRC_MAX_DD_DAY_SYM_UK100=2000
IDX_SRC_MAX_CONSEC_LOSSES_UK100=4
# Cool-off = default
# Cool-off period for UK100 after breach (minutes)
IDX_SRC_COOL_OFF_MIN_UK100=10


# --- RSI exhaustion filters (avoid chasing spikes)
IDX_RSI_OVERBOUGHT=75
IDX_RSI_OVERSOLD=25
IDX_RSI_EXHAUST_SOFT_MULT=0.9

# ATR-based profit protection (executor-level)
IDX_PROTECT_ENABLE=true
# Uses same IDX_ATR_POINTS_MULT as above
IDX_PROTECT_ATR_TRIGGER_R=1.0
IDX_PROTECT_ATR_OFFSET_R=0.3

# Optional per-symbol overrides (if set, they override the global)
HK50_PROTECT_ATR_TRIGGER_R=1.2
HK50_PROTECT_ATR_OFFSET_R=0.4

NAS100_PROTECT_ATR_TRIGGER_R=1.0
NAS100_PROTECT_ATR_OFFSET_R=0.3

UK100_PROTECT_ATR_TRIGGER_R=0.8
UK100_PROTECT_ATR_OFFSET_R=0.2

# ----------------------------------------------------------
# SPX Macro Bias (for NAS100)
# ----------------------------------------------------------
IDX_SPX_SYMBOL=SP500.s
IDX_SPX_TF=H1

# ----------------------------------------------------------
# Per-symbol Max Positions (optional pyramiding)
# ----------------------------------------------------------
HK50_MAX_POSITIONS=1
HK50_PYRAMID_MODE=false

NAS100_MAX_POSITIONS=1
NAS100_PYRAMID_MODE=false

UK100_MAX_POSITIONS=1
UK100_PYRAMID_MODE=false

# ----------------------------------------------------------
# Per-symbol ATR regime overrides
# ----------------------------------------------------------
# NAS100: quieter index
# <0.20% -> quiet, 0.20–0.50% -> normal, >0.50% -> hot
IDX_ATR_QUIET_PCT_NAS100=0.0020    # 0.20%
IDX_ATR_HOT_PCT_NAS100=0.0050   # 0.50%
IDX_MIN_ATR_PCT_NAS100=0.0010      # 0.10% minimum tradable ATR for NAS100

# HK50: naturally more volatile
# <0.40% -> quiet, 0.40–1.00% -> normal, >1.00% -> hot
# HK50
IDX_ATR_QUIET_PCT_HK50=0.0020 # 0.40%
IDX_ATR_HOT_PCT_HK50=0.0100 # 1.00%
IDX_MIN_ATR_PCT_HK50=0.0020 # 0.20% minimum tradable ATR for HK50

# UK100 (NEW)
IDX_ATR_QUIET_PCT_UK100=0.0008 # 0.08%
IDX_ATR_HOT_PCT_UK100=0.0025 # 0.25%
IDX_MIN_ATR_PCT_UK100=0.0008  # 0.08% minimum tradable ATR for UK100

# Optional: per-symbol ATR minimum floor (if needed later)
# IDX_MIN_ATR_PCT_NAS100=0.0010
# IDX_MIN_ATR_PCT_HK50=0.0020
# NAS100 standard swing lock in QUIET regime
IDX_SWING_LOCK_BARS_NAS100=3
IDX_SWING_COOLDOWN_BARS_NAS100=4
IDX_SWING_MIN_ATR_PCT_NAS100=0.0007   # NAS100 requires slightly lower minimum vol

# HK50 faster swing-lock decay (~1.5h)
IDX_SWING_LOCK_BARS_HK50=6
IDX_SWING_COOLDOWN_BARS_HK50=2
IDX_SWING_MIN_ATR_PCT_HK50=0.0015

# UK100 swing behaviour
IDX_SWING_LOCK_BARS_UK100=3        # roughly 2 hours lock on M15
IDX_SWING_COOLDOWN_BARS_UK100=3    # 45 minutes cooldown after swing
IDX_SWING_MIN_ATR_PCT_UK100=0.0005

# Make UK100 stricter
IDX_ALLOW_SOFT_SIGNALS_UK100=false
# or softer but reduced
# IDX_SOFT_SIGNAL_WEIGHT_UK100=0.65

IDX_ALLOW_SOFT_SIGNALS_HK50=true


# Keep default quiet-only swing lock globally
IDX_SWING_LOCK_REGIMES=quiet

IDX_SWING_LOCK_REGIMES_NAS100=quiet    # optional explicit

# But allow swing-lock in normal for UK100 if needed
IDX_SWING_LOCK_REGIMES_UK100=quiet


IDX_CONF_FLOOR_NORMAL_UK100=0.54
IDX_CONF_FLOOR_NORMAL_HK50=0.52
IDX_SWING_LOCK_REGIMES_HK50=quiet





# ----------------------------------------------------------
# Swing & Cooldown
# ----------------------------------------------------------
# Cooldown after a trade (already defined above under Guardrails)
# IDX_COOLDOWN_SEC=60

# Swing lockout behaviour
# Swing lockout behaviour
# After a detected swing, wait a bit before the next trade:
# 4 bars on M15 ≈ 1 hour
IDX_SWING_COOLDOWN_BARS=2

# In QUIET ATR regime only, stay in lock for this many bars after a swing:
# 12 bars on M15 ≈ 3 hours — enough to avoid chop around the same pivot
IDX_SWING_LOCK_BARS=0

# Only enforce *legacy* swing-ATR guards if some other component uses it.
# You can leave this as-is for now; the decider's new logic uses ATR level instead.
IDX_SWING_MIN_ATR_PCT=0.0005

# Extension filter (distance from EMA_SLOW in ATR units)
IDX_MAX_EXT_ATR_NORMAL=1.80
IDX_MAX_EXT_ATR_HOT=2.20
IDX_MAX_EXT_ATR_QUIET=1.20

# UK100 stricter in NORMAL (mean reversion / chop)
IDX_MAX_EXT_ATR_NORMAL_UK100=1.50

# HK50 can be a bit more extended due to its nature, but still set a cap to avoid crazy spikes
IDX_MAX_EXT_ATR_NORMAL_HK50=2.50
IDX_MAX_EXT_ATR_HOT_HK50=2.80
# =============================================================
# Step-2: Duplicate-trade prevention (spacing)
# =============================================================
IDX_MIN_TRADE_SPACING_SEC=60          # default per-symbol spacing (seconds)
IDX_MIN_TRADE_SPACING_SEC_UK100=120   # UK100: stricter spacing
IDX_MIN_TRADE_SPACING_SEC_HK50=90     # HK50: moderate spacing
IDX_MIN_TRADE_SPACING_SEC_NAS100=60   # NAS100: default

IDX_BLOCK_SAME_DIR_REENTRY=true       # only blocks within spacing window if same direction (recommended true)

# =============================================================
# Step-3: NAS100 tightening (reduce soft/neutral bleed)
# =============================================================
IDX_ALLOW_SOFT_SIGNALS_NAS100=false
IDX_NEUTRAL_CONF_BOOST_NAS100=0.07
IDX_RSI_EXHAUST_SOFT_MULT_NAS100=0.80

IDX_PYRAMID_MODE=false
IDX_EMA_GAP_MIN_POINTS=8.0
IDX_SWING_LOOKBACK=12
IDX_TRADE_ALLOWED_REGIMES=quiet,normal,hot

# Trend-only mode (IDX)
IDX_TREND_ONLY=true
# Optional per-symbol overrides
IDX_TREND_ONLY_NAS100=true
IDX_TREND_ONLY_UK100=true
IDX_TREND_ONLY_HK50=false


IDX_SOFT_SIGNAL_WEIGHT_HK50=0.75

