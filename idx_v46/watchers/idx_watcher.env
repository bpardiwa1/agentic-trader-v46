# =========================
# IDX Telegram Watcher Env
# =========================
TELEGRAM_ENABLED=true

# --- Telegram ---
TG_BOT_TOKEN=8448935427:AAFPEo6p1mmLIUR3PavzBwZOSFEFjpg70xY
TG_CHAT_ID=6842274522

# --- Watch mode: "log" (legacy) or "jsonl" (preferred) ---
# FX currently emits EVENT {...} into the daily .log files, so "log" works immediately.
WATCH_MODE=jsonl

# --- JSONL stream (optional / future) ---
# WATCH_JSONL_FILE=logs\fx_v4.6\fx_events_{date}.jsonl
WATCH_JSONL_GLOB=logs\idx_v4.6\idx_events_*.jsonl

# --- Persist offset across restarts (JSONL mode) ---
WATCH_STATE_FILE=logs\idx_v4.6\idx_watcher.state.json

# --- Only used for WATCH_MODE=log ---
WATCH_EVENT_PREFIX=EVENT

# --- Event filters (comma-separated; must match top-level "event") ---
# Recommended minimal set for trading ops:
WATCH_INCLUDE_EVENTS=ERROR,FAILED,BLOCKED,TRADE_START,EXECUTED,TRADE_END
# Drop noisy event types:
WATCH_EXCLUDE_EVENTS=SKIP,RISK,ORDER_SEND,ORDER_RESULT

# --- Optional: only alert when DECISION has side LONG/SHORT (not empty) ---
WATCH_DECISION_REQUIRE_SIDE=true

# --- Anti-spam / guardrails ---
WATCH_DEDUPE_WINDOW_SEC=900
WATCH_MIN_SECONDS_BETWEEN_ALERTS=0.2
WATCH_MAX_ALERTS_PER_5MIN=60

# --- Formatting ---
WATCH_SHOW_RAW_LINE=false
WATCH_MAX_MESSAGE_CHARS=3500

# --- Start position ---
WATCH_START_AT=tail

# --- Operational ---
WATCH_ATTACH_MESSAGE=true
WATCH_POLL_INTERVAL_SEC=0.5

# --- Heartbeat / Health ---
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL_SEC=1800          # 30 minutes
HEARTBEAT_SILENCE_ALERT_SEC=900      # alert if no EVENT lines for 15 minutes (0 disables)
HEARTBEAT_INCLUDE_FILE=true          # include current log file name
HEARTBEAT_INCLUDE_LAST_EVENT=true    # include last event + how long ago