# =============================================================
# Agentic Trader v4.6 Git Ignore Rules (Production Safe)
# =============================================================

# --- Python build & cache ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
.venv.zip

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
.DS_Store

# --- Logs & Runtime ---
logs/
*.log
report/
*.jsonl
*.state.json

# --- Backups ---
*.bkp.*
*_bkp_*.py
log.bkp.*
report.bkp.*
backup/
backups/

# --- Archives / Dumps ---
*.zip
*.tar
*.gz
*.tar.gz

# --- Generated Reports ---
*.csv

# --- Old versions (protect current modules) ---
!fx_v46/
!xau_v46/
!idx_v46/
indices_v4*/
*/v4/
*/v4.*

# --- Environment files (NEVER commit secrets) ---
*.env
.env

# --- Local test data ---
tmp/
tests/
scratch/
notebooks/
__temp__/

# --- Deployment artifacts ---
deploy-output/
dist/
build/