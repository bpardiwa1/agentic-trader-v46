# ============================================================
# NAS100 Scalper v1 — Independent Bot Env
# ============================================================

BOT_NAME=nas100_scalp_v1

# --- Symbols ---
AGENT_SYMBOLS=NAS100.s

# --- Logging (independent) ---
IDX_LOG_LEVEL=INFO
IDX_EVENTS_DIR=logs/nas100_scalp_v1
IDX_EVENTS_DAILY_ROTATE=true
IDX_EVENTS_LOG_TO_MAIN=true

# --- MT5 execution (reuse hardened IDX executor semantics) ---
MT5_DEVIATION=80
IDX_PIP_MODE=index_point
IDX_STOP_WIDEN_MULT=1.5
IDX_RETRY_BUSY_DELAY_SEC=0.6

# Guardrails (executor)
IDX_AGENT_MAX_OPEN=12
IDX_AGENT_MAX_PER_SYMBOL=1
IDX_COOLDOWN_SEC=120
IDX_BLOCK_SAME_DIRECTION=true
IDX_PYRAMID_MODE=false

# Lot sizing (keep simple & safe; tune later)
IDX_MIN_LOTS=0.05
IDX_MAX_LOTS=0.30
NAS100_MIN_LOTS=0.10
NAS100_MAX_LOTS=0.30
IDX_TRUST_WEIGHT=0.40

# Trust engine
IDX_TRUST_DEFAULT=0.50
IDX_TRUST_MIN=0.40
IDX_TRUST_MAX=0.95
IDX_TRUST_INC_SUCCESS=0.05
IDX_TRUST_DEC_FAIL=0.10
IDX_TRUST_DECAY_SEC=540000

# --- Scalper Strategy (M1 entry + M5 bias) ---
SCALP_TF_ENTRY=M1
SCALP_TF_BIAS=M5

SCALP_EMA_FAST=9
SCALP_EMA_SLOW=21
SCALP_RSI_PERIOD=14
SCALP_RSI_LONG_TH=52
SCALP_RSI_SHORT_TH=48

# Anti-chop: EMA gap minimum (points) on M1
SCALP_EMA_GAP_MIN_POINTS=5.0

# ATR band filter on M1 (ATR/price)
SCALP_ATR_PERIOD=14
SCALP_ATR_PCT_MIN=0.00025
SCALP_ATR_PCT_MAX=0.00220

# SL/TP (points) — start conservative to avoid broker stop constraints
SCALP_SL_POINTS=80
SCALP_TP_POINTS=120

# Session (MYT)
SCALP_TRADING_WINDOW_START=21:30
SCALP_TRADING_WINDOW_END=23:30
SCALP_HOT_START=22:30
SCALP_HOT_END=23:30
SCALP_HOT_ONLY=true

# Guardrails (agent/decider)
SCALP_MAX_TRADES_PER_SESSION=3
SCALP_MIN_BARS_BETWEEN_TRADES=5

# Agent loop
SCALP_POLL_SEC=5