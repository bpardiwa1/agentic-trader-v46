# =========================================================
# 🌍 Agentic Trader FX v4 — Environment Configuration
# =========================================================
# All configuration for runtime behavior, guardrails, trust,
# and dynamic lot scaling lives here.
# =========================================================

# ------------------------------
# 🔹 SYMBOLS & TIMEFRAME
# ------------------------------
AGENT_SYMBOLS=AUDUSD
TIMEFRAME=M15
AGENT_MIN_CONFIDENCE=0.45      

FX_TIMEFRAME=M15

# ------------------------------
# 🔹 ATR & VOLATILITY SETTINGS
# ------------------------------
FX_ATR_ENABLED=true

ATR_ENABLED=true
FX_ATR_ENABLE=true
USE_ATR=true

FX_ATR_PERIOD=14
FX_ATR_SL_MULT=2.0
FX_ATR_TP_MULT=3.0





# Global min/max bounds for dynamic SL/TP
FX_SL_MIN=20
FX_TP_MIN=40
FX_SL_MAX=120
FX_TP_MAX=240

# Shape of confidence effect (anchor where factor ≈ 1.0)
FX_SLTP_CONF_ANCHOR=0.60
FX_SLTP_CONF_SPAN=0.40

# Baseline ATR% for volatility factor (defaults to FX_MIN_ATR_PCT)
FX_ATR_BASE_PCT=0.0003


# ------------------------------
# 🔹 PER-SYMBOL PARAMETERS
# ------------------------------
# EURUSD
EMA_FAST_EURUSD=20
EMA_SLOW_EURUSD=50
RSI_PERIOD_EURUSD=14
RSI_LONG_TH_EURUSD=53
RSI_SHORT_TH_EURUSD=47
SL_EURUSD=40
TP_EURUSD=90
SL_MIN_EURUSD=25
SL_MAX_EURUSD=60
TP_MIN_EURUSD=55
TP_MAX_EURUSD=140

LOTS_EURUSD=0.10



# GBPUSD
EMA_FAST_GBPUSD=20
EMA_SLOW_GBPUSD=50
RSI_PERIOD_GBPUSD=14
RSI_LONG_TH_GBPUSD=53
RSI_SHORT_TH_GBPUSD=47
SL_GBPUSD=45
TP_GBPUSD=100
SL_MIN_GBPUSD=30
SL_MAX_GBPUSD=70
TP_MIN_GBPUSD=60
TP_MAX_GBPUSD=160

LOTS_GBPUSD=0.10

# USDJPY
EMA_FAST_USDJPY=14
EMA_SLOW_USDJPY=40
RSI_PERIOD_USDJPY=14
RSI_LONG_TH_USDJPY=53
RSI_SHORT_TH_USDJPY=47
SL_USDJPY=50
TP_USDJPY=110
SL_MIN_USDJPY=30
SL_MAX_USDJPY=80
TP_MIN_USDJPY=70
TP_MAX_USDJPY=170

LOTS_USDJPY=0.15

# AUDUSD
EMA_FAST_AUDUSD=20
EMA_SLOW_AUDUSD=50
RSI_PERIOD_AUDUSD=14
RSI_LONG_TH_AUDUSD=53
RSI_SHORT_TH_AUDUSD=47
SL_AUDUSD=50
TP_AUDUSD=110
SL_MIN_AUDUSD=30
SL_MAX_AUDUSD=80
TP_MIN_AUDUSD=70
TP_MAX_AUDUSD=170

LOTS_AUDUSD=0.20

# ------------------------------
# 🔹 TRUST / DYNAMIC LOT CONTROL
# ------------------------------
FX_DYNAMIC_LOTS=true           
FX_MIN_LOTS=0.03               
FX_MAX_LOTS=0.30               

# ------------------------------
# 🔹 CONFIDENCE CONTROL (trust learning)
# ------------------------------
FX_CONFIDENCE_GATE=true
FX_CONFIDENCE_LOCK_N=3
FX_CONFIDENCE_RESET_N=3
FX_CONFIDENCE_TRUST_N=5
FX_TRUST_DECAY_BARS=600
FX_BAR_MINUTES=15
FX_TRUST_DECAY_STEP_HIGH=0.005
FX_TRUST_DECAY_STEP_LOW=0.002

# ------------------------------
# FX regime thresholds (ATR% bands)
# ------------------------------
FX_ATR_QUIET_PCT=0.0005
FX_ATR_HOT_PCT=0.0015

# Optional per-symbol overrides:
# FX_ATR_QUIET_PCT_EURUSD=0.0004
# FX_ATR_HOT_PCT_EURUSD=0.0012


# ------------------------------
# 🔹 EXECUTION GUARDRAILS
# ------------------------------
AGENT_MAX_OPEN=10              
AGENT_MAX_PER_SYMBOL=2         
FX_MAX_SYMBOLS=5
FX_SYMBOL_BATCH_DELAY=2.0      
FX_COOLDOWN_SEC=180
FX_BLOCK_SAME_DIRECTION=true
# ------------------------------
# 🔹 BROKER EXECUTION PARAMETERS
# ------------------------------
MT5_DEVIATION=50            
MT5_STOP_WIDEN_MULT=2.0        

# ------------------------------
# 🔹 OPTIONAL SYMBOL ALIASES
# ------------------------------
FX_ALIAS_EURUSD=EURUSD-ECNc
FX_ALIAS_GBPUSD=GBPUSD-ECNc
FX_ALIAS_USDJPY=USDJPY-ECNc
FX_ALIAS_AUDUSD=AUDUSD-ECNc

# ------------------------------
# 🔹 LOGGING / MISC
# ------------------------------
LOG_LEVEL=INFO
