# =========================================================
# 🌍 Agentic Trader FX v4.6 — Environment Configuration
# =========================================================
# Streamlined and modular configuration for the v4.6 engine.
# Supports trust-decay, adaptive confidence, dynamic lot sizing,
# and execution guardrails.
# =========================================================

# ------------------------------
# 🔹 SYMBOLS & TIMEFRAME
# ------------------------------
AGENT_SYMBOLS=EURUSD-ECNc,GBPUSD-ECNc,AUDUSD-ECNc,USDJPY-ECNc
TIMEFRAME=M15
AGENT_MIN_CONFIDENCE=0.45

# Limit of symbols per loop (used in logging / future guardrails)
FX_MAX_SYMBOLS=1

# ------------------------------
# 🔹 SYMBOL ALIASES
# ------------------------------
FX_ALIAS_EURUSD=EURUSD-ECNc
FX_ALIAS_GBPUSD=GBPUSD-ECNc
FX_ALIAS_USDJPY=USDJPY-ECNc
FX_ALIAS_AUDUSD=AUDUSD-ECNc

# ------------------------------
# 🔹 ATR / VOLATILITY
# ------------------------------
FX_ATR_ENABLED=true
FX_ATR_PERIOD=14
FX_ATR_SL_MULT=2.0
FX_ATR_TP_MULT=3.0

# ------------------------------
# 🔹 PER-SYMBOL PARAMETERS
# ------------------------------
# EURUSD
EMA_FAST_EURUSD=20
EMA_SLOW_EURUSD=50
RSI_PERIOD_EURUSD=14
RSI_LONG_TH_EURUSD=52
RSI_SHORT_TH_EURUSD=48
SL_EURUSD=40
TP_EURUSD=90
LOTS_EURUSD=0.10

# GBPUSD
EMA_FAST_GBPUSD=20
EMA_SLOW_GBPUSD=50
RSI_PERIOD_GBPUSD=14
RSI_LONG_TH_GBPUSD=52
RSI_SHORT_TH_GBPUSD=48
SL_GBPUSD=45
TP_GBPUSD=100
LOTS_GBPUSD=0.10

# USDJPY
EMA_FAST_USDJPY=14
EMA_SLOW_USDJPY=40
RSI_PERIOD_USDJPY=14
RSI_LONG_TH_USDJPY=52
RSI_SHORT_TH_USDJPY=48
SL_USDJPY=50
TP_USDJPY=110
LOTS_USDJPY=0.15

# AUDUSD
EMA_FAST_AUDUSD=20
EMA_SLOW_AUDUSD=50
RSI_PERIOD_AUDUSD=14
RSI_LONG_TH_AUDUSD=52
RSI_SHORT_TH_AUDUSD=48
SL_AUDUSD=50
TP_AUDUSD=110
LOTS_AUDUSD=0.20

# Global SL/TP baselines (fallback if per-symbol missing)
FX_SL_DEFAULT=40.0
FX_TP_DEFAULT=90.0

# ------------------------------
# 🔹 TRUST / DYNAMIC LOT CONTROL
# ------------------------------
FX_DYNAMIC_LOTS=true
FX_MIN_LOTS=0.03
FX_MAX_LOTS=0.30
FX_TRUST_DECAY_MINUTES=180

# ------------------------------
# 🔹 EXECUTION GUARDRAILS
# ------------------------------
AGENT_MAX_OPEN=15
AGENT_MAX_PER_SYMBOL=2
FX_SYMBOL_BATCH_DELAY=2.0
FX_COOLDOWN_SEC=180
FX_BLOCK_SAME_DIRECTION=false

# Whether to enforce a hard confidence gate in the agent
FX_CONFIDENCE_GATE=true

# ------------------------------
# 🔹 BROKER EXECUTION PARAMETERS
# ------------------------------
MT5_DEVIATION=50
MT5_STOP_WIDEN_MULT=2.0

# ------------------------------
# 🔹 LOGGING / MISC
# ------------------------------
FX_LOG_LEVEL=INFO

# ============================
# 🔹 FX v4.6 Direction Policy
# ============================

# How strict should the direction filter be?
#   strict     = require trend + RSI strength + ATR above FX_MIN_ATR_PCT
#   flexible   = require trend + ATR, looser RSI requirement
#   aggressive = allow any aligned side, still blocks clearly wrong trend
FX_TRADE_POLICY=flexible

# Policy-specific confidence floors (aligned with XAU/IDX)
FX_MIN_CONF_STRICT=0.58
FX_MIN_CONF_FLEX=0.48
FX_MIN_CONF_AGGR=0.45

# Minimum ATR% for volatility to be considered "good enough" for FX trades.
# If ATR% < FX_MIN_ATR_PCT, strict/flexible policy can block trades.
FX_MIN_ATR_PCT=0.0003

# Weight of trust vs raw indicator confidence in adjusted_confidence blending.
FX_TRUST_WEIGHT=0.40


# ==========================================
# 🔹 Parameters for avoiding Session risks:
# ===========================================

FX_SRC_MAX_DD_DAY_ACC=3000        # stop all FX if account DD for today ≤ -300
FX_SRC_MAX_DD_DAY_SYM=1000        # per-symbol daily DD (EURUSD-ECNc, etc.)
FX_SRC_MAX_CONSEC_LOSSES=3       # max 3 losing trades in a row per symbol
FX_SRC_COOL_OFF_MIN=60           # cooloff duration in minutes

# ============================================================
# Trend-only mode (FX) — require H1 trend and only trade with it
# ============================================================

FX_TREND_ONLY=true

# Optional per-symbol overrides (base symbols, not -ECNc)
FX_TREND_ONLY_EURUSD=true
FX_TREND_ONLY_GBPUSD=true
FX_TREND_ONLY_AUDUSD=true
FX_TREND_ONLY_USDJPY=true

# --- FX Event Sink (JSONL) ---
FX_EVENTS_DIR=logs/fx_v4.6
FX_EVENTS_DAILY_ROTATE=true
# --- FX Event Sink verbosity ---
FX_EVENTS_LOG_TO_MAIN=false